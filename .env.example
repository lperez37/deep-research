# Required: comma-separated Tavily API keys
TAVILY_API_KEYS=tvly-key1,tvly-key2

# Monthly credit limit per key (free tier = 1000)
CREDITS_PER_KEY=1000

# Key selection: round-robin (default)
ROUTING_STRATEGY=round-robin

# SQLite database path for credit tracking
DB_PATH=/data/credits.db

# Tavily API base URL (change for testing/mocking)
TAVILY_BASE_URL=https://api.tavily.com

# MCP transport: stdio (default) | http | sse
TRANSPORT=stdio
HOST=0.0.0.0
PORT=8000

# Optional: bearer token to protect the MCP server
# Leave empty or unset for no auth
AUTH_TOKEN=
